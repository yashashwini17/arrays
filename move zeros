class Solution:
    def moveZeroes(self, nums: List[int]) -> None:
            
            j = 0  # position to place next non-zero
            
            for i in range(len(nums)):
                if nums[i] != 0:
                    nums[j] = nums[i]
                    j += 1
            
            # fill remaining positions with zeros
            for i in range(j, len(nums)):
                nums[i] = 0

            return nums
